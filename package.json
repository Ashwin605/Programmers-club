{
  "name": "programmers-club-website",
  "version": "1.0.0",
  "description": "Root package for Programmers Club website",
  "scripts": {
    "start": "npm start --prefix server",
    "dev": "npm-run-all --parallel server client",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "build": "npm install --prefix client && npm run build --prefix client",
    "install-all": "npm-run-all install-main install-server install-client",
    "install-main": "npm install",
    "install-server": "npm install --prefix server",
    "install-client": "npm install --prefix client"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2"
  }
}
